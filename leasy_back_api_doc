  a:hover{text-decoration:underline}
  .layout{display:grid;grid-template-columns: 280px 1fr; min-height:100vh}
  nav{background:#0a0f1c;border-right:1px solid var(--border);padding:20px;position:sticky;top:0;height:100vh;overflow:auto}
  .brand{font-weight:800;letter-spacing:.3px;margin-bottom:10px}
  .muted{color:var(--muted)}
  .nav-section{margin-top:16px}
  .nav-section h4{margin:10px 0 6px 0;font-size:12px;color:#93c5fd;text-transform:uppercase;letter-spacing:.08em}
  .nav ul{list-style:none;padding-left:0;margin:0}
