    "salutation": "Herr",
    "first_name": "Max",
    "last_name": "Mustermann",
    "international_prefix": "+49",
    "primary_phone_number": "301234567"
  }
}</code></pre>
        <h3>Response 200</h3>
        <pre><code class="json">{
