        <h3>Request</h3>
        <pre><code class="json">{
  "company_name": "TechCorp GmbH",
  "vat_id": "DE123456789",
  "logo_url": "https://techcorp.com/logo.png",
  "contact_email": "info@techcorp.com",
  "address": {
    "street": "Musterstraße",
    "number": "42",
    "zip_code": "10115",
    "city": "Berlin",
    "country": "Germany"
  },
